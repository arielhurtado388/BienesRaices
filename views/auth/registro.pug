extends ../layout/index

block contenido 
    .p-10
        h1.text-4xl.my-10.font-extrabold.text-center Bienes
            span.font-normal Raíces
        h2(class="text-center text-2xl font-extrabold")= pagina

        if errores
            div(class="max-w-md mx-auto my-10")
                each error in errores
                    p(class="bg-red-500 text-white uppercase text-xs text-center p-2 mb-1 font-bold")= error.msg

        .mt-8.mx-auto.max-w-md
            .bg-white.py-8.px-4.shadow
                form(class="space-y-5" method="POST" action="/auth/registro" novalidate)
                    div 
                        label(class="block text-sm uppercase text-gray-500 mb-4 font-bold")(for="nombre") Nombre
                        input#nombre(class="w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400")(placeholder="Tu nombre" type="text" name="nombre" value= usuario ? usuario.nombre : "")
                    
                    div 
                        label(class="block text-sm uppercase text-gray-500 mb-4 font-bold")(for="correo") Correo
                        input#correo(class="w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400")(placeholder="Tu correo" type="email" name="correo" value= usuario ? usuario.correo : "")
                    
                    div 
                        label(class="block text-sm uppercase text-gray-500 mb-4 font-bold")(for="password") Contraseña
                        input#password(class="w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400")(placeholder="Tu contraseña" type="password" name="password")
                    
                    div 
                        label(class="block text-sm uppercase text-gray-500 mb-4 font-bold")(for="repetir_password") Repite tu contraseña
                        input#repetir_password(class="w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400")(placeholder="Repite tu contraseña" type="password" name="repetir_password")

                    div.flex.items-center.justify-between
                        a(class="text-gray-500 text-xs"  href="/auth/login") ¿Ya tienes cuenta? Inicia sesión
                        a(class="text-gray-500 text-xs"  href="/auth/olvide") Olvidé mi contraseña

                    input(class="w-full bg-indigo-600 hover:bg-indigo-700 cursor-pointer text-white font-bold py-3" type="submit" value="Crear cuenta")