extends ../layout/index

block contenido 
    .p-10
        h1.text-4xl.my-10.font-extrabold.text-center Bienes
            span.font-normal Raíces
        h2(class="text-center text-2xl font-extrabold")= pagina

        if errores
            div(class="max-w-md mx-auto my-10")
                each error in errores
                    p(class="bg-red-500 text-white uppercase text-xs text-center p-2 mb-1 font-bold")= error.msg

        .mt-8.mx-auto.max-w-md
            .bg-white.py-8.px-4.shadow
                form(class="space-y-5" method="POST" novalidate)

                    input(type="hidden" name="_csrf" value= csrfToken)

                    div 
                        label(class="block text-sm uppercase text-gray-500 mb-4 font-bold")(for="password") Nueva contraseña
                        input#password(class="w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400")(placeholder="Tu nueva contraseña" type="password" name="password")                  

                    input(class="w-full bg-indigo-600 hover:bg-indigo-700 cursor-pointer text-white font-bold py-3" type="submit" value="Guardar contraseña")